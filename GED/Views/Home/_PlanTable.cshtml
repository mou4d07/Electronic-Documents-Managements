@model IEnumerable<PlanViewModel>

@{
    int totalCount = (int)ViewData["TotalCount"]!;
    int page = (int)ViewData["Page"]!;
    int pageSize = (int)ViewData["PageSize"]!;
    int totalPages = (int)Math.Ceiling((double)totalCount / pageSize);
    string searchTerm = ViewData["SearchTerm"] as string ?? "";
}

@if (!string.IsNullOrEmpty(searchTerm))
{
    <div class="alert alert-info mb-3">
        Résultat de recherche pour : "<strong>@searchTerm</strong>" à @totalCount plan(s) trouvé(s)
    </div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nom de fichier</th>
            <th>Désignation</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@System.IO.Path.GetFileNameWithoutExtension(item.FileName)</td>
                    <td>@item.Designation</td>
                    <td>
                        <a asp-action="Show" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                            <i class="fas fa-eye"></i> Voir plan
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="3" class="text-center py-4 text-muted">
                    <i class="fas fa-search fa-2x mb-2"></i><br />
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <text>Aucun plan trouvé pour votre recherche.</text>
                    }
                    else
                    {
                        <text>Aucun plan disponible.</text>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (totalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">

            <!-- Previous button -->
            <li class="page-item @(page == 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(page - 1)"
                   asp-route-searchTerm="@searchTerm"
                   aria-label="Précédent">
                    &laquo;
                </a>
            </li>

            <!-- First page and ellipsis -->
            @if (page > 3)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-page="1" asp-route-searchTerm="@searchTerm">1</a>
                </li>
                @if (page > 4)
                {
                    <li class="page-item disabled"><span class="page-link">...</span></li>
                }
            }

            <!-- Pages around current -->
            @for (int i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@searchTerm">@i</a>
                </li>
            }

            <!-- Last page and ellipsis -->
            @if (page < totalPages - 2)
            {
                @if (page < totalPages - 3)
                {
                    <li class="page-item disabled"><span class="page-link">...</span></li>
                }
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-page="@totalPages" asp-route-searchTerm="@searchTerm">@totalPages</a>
                </li>
            }

            <!-- Next button -->
            <li class="page-item @(page == totalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(page + 1)"
                   asp-route-searchTerm="@searchTerm"
                   aria-label="Suivant">
                    &raquo;
                </a>
            </li>
        </ul>
    </nav>

    <div class="text-center text-muted mt-2">
        Page @(page) sur @totalPages
    </div>
}
